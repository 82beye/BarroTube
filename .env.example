# BarroTube — Environment Configuration
# 이 파일을 복사하여 .env로 사용하세요: cp .env.example .env
# .env 파일은 .gitignore에 의해 버전 관리에서 제외됩니다.

# ─────────────────────────────────────────────────
# 미디어 생성
# ─────────────────────────────────────────────────

# TTS 음성 합성 (필수)
ELEVENLABS_API_KEY=

# 이미지 생성 - 1차 (필수, 택1)
FAL_API_KEY=

# 이미지 생성 - 2차 폴백 (선택)
REPLICATE_API_KEY=

# ─────────────────────────────────────────────────
# YouTube
# ─────────────────────────────────────────────────

# YouTube Data API - 검색/메타데이터 조회 (필수)
YOUTUBE_DATA_API_KEY=

# YouTube OAuth - 업로드용 (S11 단계에서 필수, 채널별)
# OAuth 토큰은 JSON 형식: {"access_token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=

# Google AI API - 이미지생성, 자막 생성 및 기타 LLM 활용 (선택, 택1) — Paperclip이 로컬 Claude Code 사용 시 불필요
GOOGLE_AI_API_KEY=

# ─────────────────────────────────────────────────
# 알림 (Telegram Bot)
# ─────────────────────────────────────────────────

# @BotFather에서 봇 생성 후 토큰 입력
TELEGRAM_BOT_TOKEN=

# 봇에게 메시지 보낸 후 https://api.telegram.org/bot<TOKEN>/getUpdates 로 chat_id 확인
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────
# LLM 폴백 (선택 — Paperclip이 로컬 Claude Code 사용 시 불필요)
# ─────────────────────────────────────────────────

# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=
# OPENAI_API_KEY=

# ─────────────────────────────────────────────────
# 시스템 설정
# ─────────────────────────────────────────────────

# 로그 레벨 (debug | info | warn | error)
LOG_LEVEL=info

# 타임존
TZ=Asia/Seoul
