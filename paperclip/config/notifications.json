      "episode_complete": ["telegram", "macos_notification"],
      "episode_failed": ["telegram", "macos_notification"],
      "board_approval_needed": ["telegram", "macos_notification"],
      "budget_alert": ["telegram"],
      "daily_report": ["telegram"],
      "agent_timeout": ["telegram", "macos_notification"]
    }
  }
